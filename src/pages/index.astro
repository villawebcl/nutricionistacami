>
  <Nav />
  <main>
    <Hero />
    <Problema />
    <Transformacion />
    <Servicios />
    <ComoFunciona />
    <Diferencial />
    <Testimonios />
    <SobreMi />
    <SeoLocal />
    <CtaFinal />
  </main>
  <Footer />
</Layout>
