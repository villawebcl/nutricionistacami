<style>
  .sobre { background: var(--color-beige); padding: 96px 28px; }
  .sobre-wrap {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1.2fr;
    gap: 72px; align-items: center;
  }

  /* Image col */
  .sobre-img-col { position: relative; display: flex; justify-content: center; }
  .sobre-orb {
    position: absolute; width: 340px; height: 340px;
    background: radial-gradient(circle, rgba(232,112,58,0.09) 0%, transparent 68%);
    border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%,-50%);
  }
  .sobre-card {
    width: 320px; height: 400px;
    border-radius: 28px;
    border: 1px solid var(--color-beige-border);
    box-shadow: 0 18px 52px rgba(92,61,42,0.13);
    overflow: hidden; position: relative; z-index: 2;
  }
  .sobre-photo-real {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  .sobre-badge {
    position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(232,112,58,0.15);
    border-radius: 99px; padding: 7px 16px;
    font-size: 0.78rem; font-weight: 700; color: var(--color-ink);
    white-space: nowrap; z-index: 3;
    box-shadow: 0 4px 12px rgba(92,61,42,0.1);
  }
  /* Content col */
  .sobre-paras {
    display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px;
  }
  .sobre-paras p { font-size: 0.9rem; color: var(--color-brown-light); line-height: 1.8; }
  .sobre-paras strong { color: var(--color-ink-deep); font-weight: 600; }
  .sobre-creds {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px; margin-bottom: 28px;
  }
  .cred {
    display: flex; align-items: center; gap: 9px;
    background: #fff; border: 1px solid var(--color-beige-border);
    border-radius: 12px; padding: 12px 14px;
    font-size: 0.82rem; font-weight: 500; color: var(--color-ink);
  }
  .sobre-social { display: flex; gap: 10px; flex-wrap: wrap; }
  .sobre-social-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 20px; border-radius: 999px;
    font-weight: 600; font-size: 0.85rem;
    transition: transform 0.15s, opacity 0.2s;
    min-height: 44px;
  }
  .sobre-social-btn:hover { transform: translateY(-2px); opacity: 0.9; }
  .ig { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743); color: #fff; }
  .tt {
    background: #111;
    color: #fff;
    box-shadow: 0 8px 20px rgba(17,17,17,0.16);
  }
  .wa { background: #25D366; color: #fff; }

  @media (max-width: 900px) {
    .sobre-wrap { grid-template-columns: 1fr; gap: 48px; }
    .sobre-img-col { order: -1; }
    .sobre-card { width: 260px; height: 320px; }
    .sobre-creds { grid-template-columns: 1fr; }
  }
</style>
