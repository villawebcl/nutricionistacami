<style>
  .cta {
    background: var(--color-ink-deep);
    padding: 100px 28px;
    position: relative; overflow: hidden;
  }
  .cta::before {
    content: '';
    position: absolute; top: -280px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(232,112,58,0.13) 0%, transparent 60%);
    pointer-events: none;
  }
  .cta-wrap {
    max-width: 640px; margin: 0 auto;
    text-align: center; position: relative; z-index: 1;
  }
  .cta-urgencia {
    display: inline-block;
    background: rgba(232,112,58,0.18); border: 1px solid rgba(232,112,58,0.35);
    color: var(--color-orange-light);
    padding: 7px 18px; border-radius: 99px;
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 28px;
  }
  .cta-title {
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    color: var(--color-beige); margin-bottom: 20px;
  }
  .cta-title em { color: var(--color-orange-light); font-style: italic; }
  .cta-sub {
    font-size: 1rem; color: rgba(250,246,241,0.65);
    line-height: 1.75; margin-bottom: 44px;
  }
  .cta-sub strong { color: var(--color-orange-light); }
  .cta-actions {
    display: flex; flex-direction: column;
    align-items: center; gap: 14px; margin-bottom: 36px;
  }
  .cta-main-btn {
    display: inline-flex; align-items: center; gap: 12px;
    background: var(--color-orange); color: #fff;
    padding: 14px 32px; border-radius: 999px;
    font-weight: 700; font-size: 0.95rem;
    box-shadow: 0 10px 32px rgba(232,112,58,0.35);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .cta-main-btn:hover {
    background: var(--color-orange-dark);
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(232,112,58,0.45);
  }
  .cta-contact { font-size: 0.82rem; color: rgba(250,246,241,0.45); }
  .cta-trust { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; }
  .cta-trust span { font-size: 0.82rem; color: rgba(250,246,241,0.5); font-weight: 500; }

  @media (max-width: 768px) {
    .cta-main-btn {
      padding: 14px 28px;
      font-size: 0.92rem;
      gap: 10px;
    }
  }
</style>
