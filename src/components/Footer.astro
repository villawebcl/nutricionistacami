<style>
  .footer {
    background: var(--color-ink-deep);
    padding: 60px 28px 0;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(180px, 0.8fr) minmax(220px, 1fr);
    gap: 56px; padding-bottom: 48px;
    align-items: start;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .footer-brand {
    max-width: 420px;
  }
  .footer-logo { width: 260px; margin-bottom: 18px; }
  .footer-brand p {
    max-width: 360px;
    font-size: 0.82rem; color: rgba(250,246,241,0.45); line-height: 1.7;
  }
  .footer-nav h4, .footer-contact h4 {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--color-orange-light);
    margin-bottom: 16px; font-family: var(--font-sans);
  }
  .footer-nav ul, .footer-contact ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .footer-nav a, .footer-contact a {
    font-size: 0.85rem; color: rgba(250,246,241,0.55);
    transition: color 0.2s; display: flex; align-items: center; gap: 8px;
  }
  .footer-nav a:hover, .footer-contact a:hover { color: var(--color-orange-light); }
  .footer-loc { font-size: 0.82rem; color: rgba(250,246,241,0.4); display: flex; align-items: center; gap: 8px; }
  .footer-bottom {
    max-width: 1100px; margin: 0 auto;
    padding: 22px 0 26px; text-align: center;
    display: flex; flex-direction: column; gap: 4px;
  }
  .footer-bottom p { font-size: 0.78rem; color: rgba(250,246,241,0.28); }
  .footer-credit {
    font-size: 0.74rem;
    color: rgba(250,246,241,0.34);
  }
  .footer-credit a {
    color: rgba(250,246,241,0.52);
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .footer-credit a:hover {
    color: var(--color-orange-light);
    opacity: 0.9;
  }
  .footer-seo { font-size: 0.68rem !important; }

  /* Floating button */
  .wa-float {
    position: fixed; bottom: 24px; right: 24px;
    width: 56px; height: 56px;
    background: #25D366; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 20px rgba(37,211,102,0.4);
    z-index: 999; transition: transform 0.2s;
  }
  .wa-float:hover { transform: scale(1.08); }
  .wa-tooltip {
    position: absolute; right: 66px;
    background: var(--color-ink-deep); color: #fff;
    padding: 5px 12px; border-radius: 8px;
    font-size: 0.78rem; font-weight: 600; white-space: nowrap;
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .wa-tooltip::after {
    content: '';
    position: absolute; right: -5px; top: 50%; transform: translateY(-50%);
    border-left: 5px solid var(--color-ink-deep);
    border-top: 4px solid transparent; border-bottom: 4px solid transparent;
  }
  .wa-float:hover .wa-tooltip { opacity: 1; }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-brand { text-align: center; }
    .footer-logo {
      width: 260px;
      max-width: 100%;
      margin: 0 auto 18px;
      display: block;
    }
    .footer-brand p { margin-left: auto; margin-right: auto; }
    .footer-nav, .footer-contact { text-align: center; }
    .footer-nav ul, .footer-contact ul { align-items: center; }
    .wa-float { bottom: 16px; right: 16px; width: 50px; height: 50px; }
  }
</style>
