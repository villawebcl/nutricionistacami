---
<section class="hero" id="inicio">
  <div class="hero-wrap">

    <!-- Left col -->
    <div class="hero-left">
      <span class="hero-label section-label">Nutricionista &amp; Coach Fitness · Santo Domingo, Chile</span>

      <h1 class="hero-h1">
        Tu cuerpo puede<br />
        más de lo que<br />
        <em>tú crees.</em>
      </h1>

      <p class="hero-sub">
        Soy nutricionista en Santo Domingo, Chile, especializada en mujeres.
        Deja de luchar contra tu cuerpo y empieza a transformarte con
        un plan real, personalizado y acompañamiento de verdad.
      </p>

      <div class="hero-actions">
        <a
          href="https://wa.me/56972586313?text=Hola%20Cami!%20Vi%20tu%20p%C3%A1gina%20y%20quiero%20comenzar%20mi%20transformaci%C3%B3n%20%F0%9F%92%AA"
          target="_blank"
          rel="noopener"
          aria-label="Contactar a Camila Aguayo por WhatsApp para iniciar asesoría nutricional"
          class="btn-orange hero-btn"
        >
          <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          Quiero mi consulta gratis
        </a>
        <a href="#servicios" class="hero-ghost">Ver programas →</a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <strong>+150</strong>
          <span>Mujeres<br/>transformadas</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <strong>100%</strong>
          <span>Planes<br/>personalizados</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <strong>3 en 1</strong>
          <span>Nutrición +<br/>Fitness + Coaching</span>
        </div>
      </div>
    </div>

    <!-- Right col -->
    <div class="hero-right">
      <div class="hero-orb"></div>
      <div class="hero-card">
        <img
          src="/cami-retrato.jpg"
          alt="Camila Aguayo, nutricionista y coach fitness para mujeres en Santo Domingo Chile"
          class="hero-photo-real"
          width="360"
          height="440"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="chip chip-a">
        <span class="chip-icon">🥗</span>
        <span>Nutrición real</span>
      </div>
      <div class="chip chip-b">
        <span class="chip-icon">💪</span>
        <span>Entrenamiento a tu medida</span>
      </div>
    </div>

  </div>

  <!-- Divider -->
  <div class="hero-divider">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" fill="none">
      <path d="M0,36 C480,72 960,0 1440,36 L1440,72 L0,72 Z" fill="var(--color-beige)"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    padding-top: 92px;
    background: linear-gradient(150deg, var(--color-cream) 0%, var(--color-beige) 55%, #F5E6D2 100%);
    position: relative; display: flex; flex-direction: column;
  }
  .hero-wrap {
    flex: 1;
    max-width: 1200px; margin: 0 auto;
    padding: 72px 28px 80px;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 56px;
  }

  /* Left */
  .hero-h1 {
    font-size: clamp(2.6rem, 4.5vw, 4rem);
    color: var(--color-ink-deep);
    font-weight: 700; margin-bottom: 22px;
  }
  .hero-h1 em { color: var(--color-orange); font-style: italic; }
  .hero-sub {
    font-size: 1.05rem; color: var(--color-brown-light);
    line-height: 1.8; max-width: 480px; margin-bottom: 36px;
  }
  .hero-actions { display: flex; align-items: center; gap: 20px; margin-bottom: 48px; flex-wrap: wrap; }
  .hero-btn { font-size: 1rem; padding: 15px 34px; box-shadow: 0 6px 24px rgba(232,112,58,0.28); }
  .hero-ghost {
    font-size: 0.9rem; font-weight: 600; color: var(--color-orange);
    padding-bottom: 2px; border-bottom: 1.5px solid var(--color-orange);
    transition: opacity 0.2s;
  }
  .hero-ghost:hover { opacity: 0.75; }
  .hero-stats { display: flex; gap: 28px; align-items: center; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 3px; }
  .stat strong {
    font-size: 1.6rem; font-family: var(--font-serif);
    font-weight: 700; color: var(--color-ink-deep); line-height: 1;
  }
  .stat span { font-size: 0.72rem; color: var(--color-brown-light); font-weight: 500; line-height: 1.4; }
  .stat-sep { width: 1px; height: 40px; background: var(--color-beige-dark); }

  /* Right */
  .hero-right {
    position: relative; display: flex;
    justify-content: center; align-items: center;
  }
  .hero-orb {
    position: absolute; width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(232,112,58,0.09) 0%, transparent 68%);
    border-radius: 50%; pointer-events: none;
  }
  .hero-card {
    width: 360px; height: 440px;
    background: #fff;
    border-radius: 28px;
    border: 1px solid var(--color-beige-border);
    box-shadow: 0 20px 56px rgba(92,61,42,0.11), 0 2px 8px rgba(92,61,42,0.05);
    overflow: hidden; z-index: 2; position: relative;
  }
  .hero-photo-real {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .chip {
    position: absolute; z-index: 4;
    background: #fff;
    border: 1px solid var(--color-beige-border);
    border-radius: 14px;
    padding: 10px 16px;
    display: flex; align-items: center; gap: 9px;
    font-size: 0.8rem; font-weight: 600; color: var(--color-ink);
    box-shadow: 0 6px 18px rgba(92,61,42,0.09);
    white-space: nowrap;
  }
  .chip-icon { font-size: 1.1rem; }
  .chip-a { bottom: 56px; left: -12px; }
  .chip-b { top: 56px; right: -12px; }
  .hero-divider { height: 72px; }
  .hero-divider svg { width: 100%; height: 100%; }

  @media (max-width: 900px) {
    .hero-wrap {
      grid-template-columns: 1fr; text-align: center;
      padding: 48px 20px 60px;
    }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; }
    .hero-right { order: -1; }
    .hero-card { width: 280px; height: 340px; }
    .hero-orb { width: 300px; height: 300px; }
    .chip-a { bottom: 16px; left: 8px; }
    .chip-b { top: 16px; right: 8px; }
  }
</style>
